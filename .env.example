# Copy to .env and fill in your values
# In sandbox: OPENAI_BASE_URL is set by validator gateway; OPENAI_API_KEY from your config

# Local development - use your OpenAI key
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override model
OPENAI_MODEL=gpt-4o-mini
# Optional: replay known successful trajectories by task_id
GATEWAY_ALLOWED_PROVIDERS=openai

# AGENT_USE_TASK_KNOWLEDGE=1
# Optional: custom path for baseline action dataset
# AGENT_TASK_KNOWLEDGE_PATH=/app/data/baseline_actions.json
# Optional: enable aggressive rescue heuristics (scroll/wait/done guards)
# AGENT_ENABLE_RESCUE=0

# Sandbox: validator sets OPENAI_BASE_URL to gateway (e.g. http://sandbox-gateway:9000/openai)
# OPENAI_BASE_URL=http://sandbox-gateway:9000/openai
